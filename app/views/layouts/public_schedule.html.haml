!!!
%html{lang: "en"}
  %head
    %meta{charset: "utf-8"}
    - if content_for? :title
      %title= yield :title
    - else
      %title= "#{schedule_title} :: Fahrplan"

    %link{rel: "icon", type: "image/svg+xml", href: "/favicon.svg"}
    %meta{name: "title", content: "#{schedule_title} Fahrplan"}
    %meta{name: "description", content: "Schedule, talks and talk submissions for #{schedule_title}"}
    %meta{name: "application-name", content: "frab"}
    %meta{name: "generator", content: "frab"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %meta{name: "theme-color", content: "##{@conference.color.presence || '1f1fa3'}"}
    %meta{name: "HandheldFriendly", content: "True"}
    %meta{name: "robots", content: "index, follow"}
    = stylesheet_link_tag 'public_schedule'
    %link{rel: "stylesheet", href: public_schedule_style_path(format: :css)}
    = javascript_include_tag 'bootstrap.bundle'
    = javascript_include_tag 'public_schedule'

  %body{"data-datetimeformat" => "YYYY-MM-DD HH:mm:ss", "data-dateformat" => "YYYY-MM-DD", "data-datetimelocale" => "en"}
    %header.ps-topbar
      .ps-topbar__inner
        %h1.ps-topbar__title
          - if @conference.logo.present?
            = link_to public_schedule_index_path, title: schedule_title do
              = image_tag @conference.logo.url(:original), alt: schedule_title, class: "ps-topbar__logo"
          - else
            = link_to schedule_title, public_schedule_index_path
        %button#dark-mode-toggle.ps-theme-toggle{onclick: "window.toggleDarkMode && window.toggleDarkMode()"}
          %i.bi.bi-moon-fill
          %span.visually-hidden Toggle dark mode

    - unless feedback_page?
      %nav.ps-nav
        .ps-nav__inner
          .ps-nav__tabs
            = link_to t('public.schedule.nav.index'), public_schedule_index_path, class: "ps-tab #{'active' if selected(/schedule$/)}"
            - @conference.days.each_with_index do |day, index|
              - day_number = index + 1
              - day_label = @conference.days.length > 1 ? l(day.start_date, format: :day) : t('public.schedule.nav.schedule')
              - if day.rooms_with_events.any?
                = link_to day_label, public_schedule_path(day: day_number), class: "ps-tab #{'active' if day_selected(day_number)}"
              - else
                %span.ps-tab.disabled= day_label
            = link_to t('public.schedule.nav.speakers'), public_speakers_path, class: "ps-tab #{'active' if selected(/speakers.*$/)}"
            = link_to t('public.schedule.nav.events'), public_events_path, class: "ps-tab #{'active' if selected(/events.*$/)}"
            = link_to t('.timeline'), public_timeline_path, class: "ps-tab #{'active' if selected(/timeline.*$/)}"
            = link_to t('.booklet'), public_booklet_path, class: "ps-tab #{'active' if selected(/booklet.*$/)}"

          - if @conference.schedule_version.present?
            .ps-nav__extra
              .dropdown
                %button.btn.btn-outline-secondary.btn-sm.dropdown-toggle{"data-bs-toggle" => "dropdown", "aria-expanded" => "false"}
                  = @conference.schedule_version
                %ul.dropdown-menu.dropdown-menu-end
                  %li
                    = link_to "#{public_schedule_index_path}.json", class: "dropdown-item" do
                      %i.bi.bi-filetype-json.me-2
                      JSON (frab compatible)
                  %li
                    = link_to "#{public_schedule_index_path}.xcal", class: "dropdown-item" do
                      %i.bi.bi-calendar.me-2
                      XCal (frab compatible)
                  %li
                    = link_to "#{public_schedule_index_path}.xml", class: "dropdown-item" do
                      %i.bi.bi-code-slash.me-2
                      XML (frab compatible)

    %main.ps-main{class: content_for?(:narrow_page) ? 'ps-main--narrow' : nil}
      = yield :track_menu
      = yield

    %footer.ps-footer
      = raw(markdown_render(t('conferences_module.footer')))
