- content_for :title do
  = "#{day_title} | #{schedule_title}"

%h2.ps-page-title= day_title

- if @view_model.room_slice_names.count > 1
  .meta-chips.mb-3
    - @view_model.room_slice_names.each_with_index do |rooms, slice_index|
      %a.meta-chip{href: "#rooms-#{slice_index}"}
        %i.bi.bi-building
        = rooms.join(', ')

/ Desktop schedule grid
.d-none.d-lg-block
  - count = 0
  - @view_model.room_slices do |rooms|
    %section.mb-4{id: "rooms-#{count}"}
      - if @view_model.room_slice_names.count > 1
        %h3.ps-section-title= @view_model.room_slice_names[count].join(', ')
      - count += 1

      .schedule-grid
        %table.schedule-table
          %thead
            %tr
              %th.time-column
              - rooms.each do |room|
                %th.room-column{title: room.name}= room.name
          %tbody
            - skip_rows = rooms.inject({}) { |h,r| h.merge(r => 0) }
            - @view_model.schedule_grid_data.each do |timeslot|
              %tr{class: timeslot[:show_time] ? 'hour-row' : nil}
                %td.time-cell
                  - if timeslot[:show_time]
                    = timeslot[:time].strftime("%H:%M")

                - rooms.each do |room|
                  - skip_rows[room] -= 1
                  - next if skip_rows[room] > 0
                  - room_data = timeslot[:rooms][room]
                  - if room_data[:type] == :event
                    - event = room_data[:event]
                    - skip_rows[room] = room_data[:rowspan]
                    %td.event-cell{rowspan: room_data[:rowspan], style: "height: #{room_data[:height]}px;"}
                      = link_to public_event_path(id: event.id), class: "event-card #{track_class(event)}" do
                        .event-card__title= event.title
                        - if event.speakers.any? && room_data[:height] >= 96
                          .event-card__speakers= event.speakers.map(&:public_name).join(", ")
                        .event-card__footer
                          - if event.track.present?
                            %span.track-pill{title: event.track.name}
                              %span.track-pill__name= event.track.name
                          - if event.time_slots
                            %span.event-card__time= "#{event.time_slots * @conference.timeslot_duration} min"
                  - else
                    %td.empty-cell

/ Mobile per-room lists
.d-lg-none
  - @view_model.mobile_schedule_data.each do |room_data|
    .room-block
      .room-block__name= room_data[:room].name
      - if room_data[:events].any?
        .session-list
          - room_data[:events].each do |event|
            = link_to public_event_path(id: event.id), class: "session-row #{track_class(event)}" do
              .session-row__time
                .session-row__start= l event.start_time, format: :time
                - if event.time_slots
                  .session-row__duration= "#{event.time_slots * @conference.timeslot_duration} min"
              .session-row__body
                %h3.session-row__title= event.title
                - if event.subtitle.present?
                  .session-row__subtitle= event.subtitle
                .session-row__meta
                  - if event.speakers.any?
                    %span
                      %i.bi.bi-person
                      = event.speakers.map(&:public_name).join(", ")
                  - if event.track.present?
                    %span.track-pill{title: event.track.name}
                      %span.track-pill__name= event.track.name
                  - if event.language.present? && @conference.languages_including_subs.count > 1
                    %span
                      %i.bi.bi-translate
                      = event.language
      - else
        %p.text-muted No events scheduled
