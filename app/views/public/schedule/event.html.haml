- content_for :title do
  = "#{event_title} | #{schedule_title}"

- event = @view_model.event
%article{class: track_class(event)}
  %header.mb-4
    - if event.event_type.present?
      .event-page__type= t("options.#{event.event_type}", default: event.event_type)
    %h2.event-page__title= event.title
    - if event.subtitle.present?
      %p.event-page__subtitle= event.subtitle

    .meta-chips
      %span.meta-chip
        %i.bi.bi-calendar3
        = l(event.start_time.to_date, format: :long)
      %span.meta-chip
        %i.bi.bi-clock
        %time{datetime: event.start_time.strftime("%Y-%m-%d %H:%M")}= l event.start_time, format: :time
        –
        %time{datetime: event.end_time.strftime("%Y-%m-%d %H:%M")}= l event.end_time, format: :time
      - if event.room.present?
        %span.meta-chip
          %i.bi.bi-geo-alt
          = event.room.name
      - if event.language.present? && @conference.languages_including_subs.count > 1
        %span.meta-chip
          %i.bi.bi-translate
          = event.language
      - if event.track.present?
        %span.meta-chip.meta-chip--track{title: event.track.name}
          %span.track-name-truncate= event.track.name

  .row.g-4
    .col-12.col-lg-8
      - if event.logo.present?
        .mb-4
          = link_to event.logo.url, "data-lightbox" => event.logo do
            = image_box(event.logo, :large, class: "img-fluid rounded", loading: "lazy", alt: "Event image")

      - if event.do_not_record
        .alert.alert-warning
          %i.bi.bi-exclamation-triangle.me-2
          %strong= t '.no_recording'

      - if event.abstract.present?
        .content-card
          .event-page__abstract= simple_format event.abstract

      - if event.description.present?
        .content-card
          .event-page__description= simple_format event.description

    .col-12.col-lg-4
      - if event.speakers.any?
        %h5.sidebar-heading= t('public.schedule.nav.speakers')
        - event.speakers.each do |speaker|
          = link_to public_speaker_path(id: speaker.id), class: "speaker-card mb-2" do
            .speaker-card__head
              - if speaker.avatar.present?
                = image_box speaker.avatar, :small, class: "avatar avatar--sm", loading: "lazy", alt: "The speaker's profile picture"
              - else
                .avatar-placeholder.avatar--sm
                  %i.bi.bi-person
              %h6.speaker-card__name= speaker.public_name
            - if speaker.abstract.present?
              %p.speaker-card__bio= text_preview(speaker.abstract, length: 100)

      %h5.sidebar-heading= t '.links'
      .sidebar-links
        = link_to public_event_path(id: event.id, format: :ics) do
          %i.bi.bi-calendar
          iCalendar
        - event.links.each do |link|
          = link_to link.url, target: "_blank" do
            %i.bi.bi-box-arrow-up-right
            = link.title
        - if event.video_url
          = link_to event.video_url, target: "_blank" do
            %i.bi.bi-play-circle
            Video
        - event.event_attachments.is_public.each do |attachment|
          = link_to attachment.attachment.url, target: "_blank" do
            %i.bi.bi-file-earmark
            = attachment.link_title

      - if @conference.feedback_enabled?
        %h5.sidebar-heading= t '.feedback'
        = link_to new_public_event_feedback_url(event_id: event), class: "btn btn-outline-secondary btn-sm" do
          %i.bi.bi-chat.me-1
          = t('.feedback_link')

      - concurrent = (@view_model.concurrent_events || []).reject { |e| e.id == event.id }
      - if concurrent.any?
        %h5.sidebar-heading= t '.concurrent_events'
        .sidebar-links
          - concurrent.each do |concurrent_event|
            = link_to public_event_path(id: concurrent_event.id), class: track_class(concurrent_event) do
              %span.track-pill
              %span
                = concurrent_event.title
                - if concurrent_event.room.present?
                  %small.text-muted= "(#{concurrent_event.room.name})"

%script{:type => 'application/ld+json'}
  - performers = event.speakers.map { |speaker| { name: speaker.public_name, '@type': 'Person', sameAs: public_speaker_path(:id => speaker.id), image: image_path(speaker.avatar.url(:small)) } }
  :plain
    {
      "@context" : "http://schema.org",
      "@type" : "Event",
      "name" : "#{event.title}",
      "location" : {
        "@type" : "Place",
        "name" : "#{event.room.try(:name)}",
        "address" : "#{@conference.title}"
      },
      "startDate" : "#{event.start_time.strftime("%F")}T#{event.start_time.strftime("%T%z")}",
      "endDate" : "#{event.end_time.strftime("%F")}T#{event.end_time.strftime("%T%z")}",
      "performer" : #{performers.to_json},
      "inLanguage" : "#{event.language}",
      "superEvent" : {
        "@type" : "Event",
        "sameAs" : "#{public_schedule_index_path}",
        "name" : "#{@conference.title}",
        "location" : {
          "@type" : "Place",
          "name" : "#{@conference.title}",
          "address" : "#{@conference.title}"
        },
        "startDate" : "#{@conference.first_day.start_date.strftime("%F")}T#{@conference.first_day.start_date.strftime("%T%z")}"
      }
    }
