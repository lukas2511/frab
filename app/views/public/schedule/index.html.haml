- content_for :title do
  = "#{@conference.title} :: Fahrplan"

- if @conference.schedule_html_intro.present?
  .ps-intro
    != @conference.schedule_html_intro

%h2.ps-page-title= t '.schedule_index'
%p.ps-page-subtitle
  - if @conference.first_day && @conference.last_day && @conference.first_day != @conference.last_day
    = "#{l @conference.first_day.start_date.to_date, format: :long} – #{l @conference.last_day.end_date.to_date, format: :long}"
  - elsif @conference.first_day
    = l @conference.first_day.start_date.to_date, format: :long

- @conference.days.each_with_index do |day, day_index|
  - day_events = @conference.events.scheduled.joins(:room).where(start_time: day.start_date.beginning_of_day..day.start_date.end_of_day).includes(:people, :room, :translations, track: :translations).order(:start_time, 'rooms.name')
  %section{id: "day-#{day_index + 1}"}
    %h3.day-heading
      - if day.rooms_with_events.any?
        = link_to l(day.start_date.to_date, format: :long), public_schedule_path(day: day_index + 1), class: "text-decoration-none"
      - else
        = l day.start_date.to_date, format: :long

    - if day_events.any?
      - day_events.group_by(&:start_time).each do |start_time, events|
        .time-group
          %span.time-group__time= l start_time, format: :time

        .row.g-2.mb-2
          - events.each do |event|
            .col-12.col-md-6.col-lg-4
              = link_to public_event_path(id: event.id), class: "event-card #{track_class(event)}" do
                .event-card__title= event.title
                - if event.speakers.any?
                  .event-card__speakers= event.speakers.map(&:public_name).join(", ")
                .event-card__footer
                  - if event.track.present?
                    %span.track-pill
                      %span.track-pill__name= event.track.name
                  %span.event-card__time
                    %i.bi.bi-geo-alt.me-1
                    = event.room.name
    - else
      %p.text-muted= t('.no_events', default: 'No events scheduled for this day.')

.format-links
  %span= t('.export_formats', default: 'Export formats')
  = link_to public_schedule_index_path(format: 'xml') do
    %i.bi.bi-filetype-xml
    XML
  = link_to public_schedule_index_path(format: 'json') do
    %i.bi.bi-filetype-json
    JSON
  = link_to public_schedule_index_path(format: 'ics') do
    %i.bi.bi-calendar
    iCal
  = link_to public_schedule_index_path(format: 'xcal') do
    %i.bi.bi-calendar2
    xCal
  = link_to public_events_path(format: 'xls') do
    %i.bi.bi-file-earmark-spreadsheet
    Excel
  = link_to public_speakers_path(format: 'xls') do
    %i.bi.bi-people
    Speakers XLS

%script{:type => "application/ld+json"}
  :plain
    {
      "@context" : "http://schema.org",
      "@type" : "Event",
      "name" : "#{@conference.title}",
      "location" : {
        "@type" : "Place",
        "name" : "#{@conference.title}",
        "address" : "#{@conference.title}"
      },
      "startDate" : "#{@conference.first_day.start_date.strftime("%F")}T#{@conference.first_day.start_date.strftime("%T%z")}",
      "endDate" : "#{@conference.first_day.end_date.strftime("%F")}T#{@conference.first_day.end_date.strftime("%T%z")}"
    }
