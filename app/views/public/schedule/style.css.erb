<% conference_color = @conference.color.presence || '1f1fa3'
   conference_color_fg = color_dark?(conference_color) ? 'fff' : '000'
%>
:root {
  --conference-color: #<%= conference_color -%>;
  --conference-color-fg: #<%= conference_color_fg -%>;
}

.track-default {
  --track-color: #<%= conference_color -%>;
  --track-color-fg: #<%= conference_color_fg -%>;
}

<% @conference.tracks_including_subs.each do |track|
     track_color = track.color.presence || conference_color
     track_color_fg = color_dark?(track_color) ? 'fff' : '000'
%>
.track-<%= track.name.parameterize -%> {
  --track-color: #<%= track_color -%>;
  --track-color-fg: #<%= track_color_fg -%>;
}
<% end %>

/* Custom Conference CSS */

<% if @conference.schedule_custom_css.present? %>
  <%= @conference.schedule_custom_css.gsub(/\{([^}]*)\}/m){ '{' + sanitize_css($1) + '}'; } %>
<% end %>
